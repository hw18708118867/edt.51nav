---
import { getToolPath } from "@/lib/tool-links";
import type { ToolMeta } from "@/data/site-content";

interface Props {
  tool: ToolMeta;
}

const { tool } = Astro.props;
---

<a href={getToolPath(tool.category, tool.slug)} class="section-card group block transition duration-200 hover:-translate-y-1 hover:border-slate-300 hover:shadow-[0_20px_45px_rgba(15,23,42,0.08)]">
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{tool.category}</div>
      <h3 class="headline mt-3 text-xl font-semibold tracking-[-0.03em] text-slate-950">{tool.title}</h3>
    </div>
    <span class="rounded-full border border-teal-200 bg-teal-50 px-2.5 py-1 text-[11px] font-semibold text-teal-700">Free</span>
  </div>
  <p class="mt-4 text-sm leading-7 text-slate-600">{tool.description}</p>
  <div class="mt-5 flex items-center justify-between gap-4">
    <span class="text-sm font-semibold text-slate-900 transition group-hover:text-slate-950">Open tool</span>
    <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">
      {tool.category}
    </span>
  </div>
</a>
