---
import type { LearnSection as LearnSectionType } from "@/data/site-content";

interface Props {
  title?: string;
  sections: LearnSectionType[];
}

const { title = "Tutorial", sections } = Astro.props;
---

<section class="section-card">
  <div class="flex items-center justify-between gap-4">
    <h2 class="headline text-3xl font-bold tracking-tight text-slate-950">{title}</h2>
    <span class="text-sm text-slate-500">Search-friendly educational copy</span>
  </div>
  <div class="mt-8 space-y-8">
    {
      sections.map((section) => (
        <article>
          <h3 class="text-xl font-bold text-slate-950">{section.title}</h3>
          <div class="mt-3 space-y-4">
            {section.paragraphs.map((paragraph) => <p class="prose-copy">{paragraph}</p>)}
          </div>
        </article>
      ))
    }
  </div>
</section>
