---
import CopyButton from "@/components/tool/CopyButton.astro";

interface Props {
  title: string;
  description: string;
  note?: string;
  badge?: string;
  controls?: string[];
}

const { title, description, note, badge = "Browser-based tool", controls = [] } = Astro.props;
---

<section data-tool-root class="surface-strong rounded-[2rem] p-5 sm:p-6 lg:p-8">
  <div class="grid gap-8 border-b border-slate-200 pb-6 lg:grid-cols-[1fr_auto] lg:items-end">
    <div>
      <div class="eyebrow">{badge}</div>
      <h1 class="headline mt-4 text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl">{title}</h1>
      <p class="mt-3 max-w-3xl text-base leading-8 text-slate-600">{description}</p>
      {note && (
        <p class="mt-4 rounded-2xl border border-amber-200 bg-amber-50/80 px-4 py-3 text-sm leading-7 text-amber-900">
          {note}
        </p>
      )}
    </div>
    <div class="flex flex-wrap gap-3">
      {
        controls.map((label) => (
          <button type="button" class="btn-ghost" data-tool-action={label}>{label}</button>
        ))
      }
      <CopyButton />
    </div>
  </div>
  <slot />
</section>
