---
import type { ArticleMeta } from "@/data/site-content";

interface Props {
  article: ArticleMeta;
}

const { article } = Astro.props;
---

<a href={`/blog/${article.slug}/`} class="section-card group block transition duration-200 hover:-translate-y-1 hover:border-slate-300 hover:shadow-[0_20px_45px_rgba(15,23,42,0.08)]">
  <div class="flex items-center justify-between gap-4">
    <span class="eyebrow">{article.category}</span>
    <span class="text-xs font-medium text-slate-500">{article.readingTime}</span>
  </div>
  <h3 class="headline mt-5 text-xl font-semibold tracking-[-0.03em] text-slate-950">{article.title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{article.description}</p>
  <div class="mt-5 text-sm font-semibold text-slate-900 transition group-hover:text-slate-950">Read article</div>
</a>
