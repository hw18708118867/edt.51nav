---
import type { FaqItem } from "@/data/site-content";

interface Props {
  title?: string;
  faqs: FaqItem[];
}

const { title = "FAQ", faqs } = Astro.props;
---

<section class="section-card">
  <div class="flex items-center justify-between gap-4">
    <h2 class="headline text-3xl font-bold tracking-tight text-slate-950">{title}</h2>
    <span class="text-sm text-slate-500">SEO core content</span>
  </div>
  <div class="mt-6 space-y-4">
    {
      faqs.map((faq) => (
        <details class="rounded-2xl border border-slate-200 bg-white p-5">
          <summary class="cursor-pointer list-none text-base font-semibold text-slate-950">
            {faq.question}
          </summary>
          <p class="mt-3 text-sm leading-7 text-slate-600">{faq.answer}</p>
        </details>
      ))
    }
  </div>
</section>
