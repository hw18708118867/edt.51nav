---
interface Props {
  eyebrow: string;
  name: string;
  description: string;
  href: string;
}

const { eyebrow, name, description, href } = Astro.props;
---

<a href={href} class="section-card group block transition duration-200 hover:-translate-y-1 hover:border-slate-300 hover:shadow-[0_20px_45px_rgba(15,23,42,0.08)]">
  <div class="eyebrow">{eyebrow}</div>
  <h3 class="headline mt-5 text-xl font-semibold tracking-[-0.03em] text-slate-950">{name}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{description}</p>
  <div class="mt-6 text-sm font-semibold text-slate-900 transition group-hover:text-slate-950">Browse tools</div>
</a>
