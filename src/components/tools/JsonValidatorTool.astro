---
import ToolShell from "@/components/tool/ToolShell.astro";
---

<ToolShell
  title="JSON Validator"
  description="Validate JSON syntax instantly and get a parser result you can act on before sending data further downstream."
  controls={["Validate", "Clear", "Sample"]}
>
  <div class="mt-6 grid gap-6 xl:grid-cols-[1fr_320px]">
    <label class="block">
      <div class="mb-3 flex items-center justify-between gap-4">
        <span class="text-sm font-semibold text-slate-900">Input JSON</span>
        <span class="status-pill border-slate-200 bg-slate-50 text-slate-500" data-tool-status>Waiting</span>
      </div>
      <textarea class="tool-textarea min-h-[24rem] rounded-[1.5rem] bg-slate-950 text-slate-100 placeholder:text-slate-500 focus:border-sky-400 focus:ring-sky-100" data-tool-input data-code-language="json" placeholder='{"valid": true}'></textarea>
    </label>
    <label class="block">
      <div class="mb-3 flex items-center justify-between gap-4">
        <span class="text-sm font-semibold text-slate-900">Validation result</span>
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Parser output</span>
      </div>
      <textarea class="tool-textarea min-h-[24rem] rounded-[1.5rem] bg-white" data-tool-output data-code-language="text" readonly placeholder="Validation details will appear here"></textarea>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-7 text-slate-600">
        Validation is immediate and stays local to the browser, which keeps the workflow fast and private.
      </div>
    </label>
  </div>
</ToolShell>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement)) return;
    const input = root.querySelector("[data-tool-input]");
    const output = root.querySelector("[data-tool-output]");
    const status = root.querySelector("[data-tool-status]");
    if (!(input instanceof HTMLTextAreaElement) || !(output instanceof HTMLTextAreaElement) || !(status instanceof HTMLElement)) return;

    const sample = `{"service":"api","version":1,"healthy":true}`;

    const setStatus = (text, ok = true) => {
      status.textContent = text;
      status.className = `status-pill ${ok ? "border-emerald-200 bg-emerald-50 text-emerald-700" : "border-rose-200 bg-rose-50 text-rose-700"}`;
    };

    root.addEventListener("click", (event) => {
      const action = event.target instanceof Element ? event.target.closest("[data-tool-action]")?.getAttribute("data-tool-action") : null;
      if (!action) return;
      if (action === "Sample") {
        input.value = sample;
        output.value = "";
        setStatus("Sample loaded");
      } else if (action === "Clear") {
        input.value = "";
        output.value = "";
        setStatus("Ready");
      } else if (action === "Validate") {
        if (!input.value.trim()) {
          output.value = "Enter JSON to validate.";
          setStatus("Input required", false);
          return;
        }
        try {
          const parsed = JSON.parse(input.value);
          output.value = `Valid JSON\n\nTop-level type: ${Array.isArray(parsed) ? "array" : typeof parsed}\nKeys: ${parsed && typeof parsed === "object" ? Object.keys(parsed).length : 0}`;
          setStatus("JSON is valid");
        } catch (error) {
          output.value = error instanceof Error ? error.message : "Invalid JSON";
          setStatus("Invalid JSON", false);
        }
      }
    });
  })();
</script>
