---
import ToolShell from "@/components/tool/ToolShell.astro";
---

<ToolShell
  title="JSON to YAML Converter"
  description="Convert valid JSON into readable YAML for configuration workflows and human-friendly review."
  controls={["Convert", "Clear", "Sample"]}
>
  <div class="mt-6 grid gap-6 xl:grid-cols-[1fr_320px]">
    <label class="block">
      <div class="mb-3 flex items-center justify-between gap-4">
        <span class="text-sm font-semibold text-slate-900">Input JSON</span>
        <span class="status-pill border-slate-200 bg-slate-50 text-slate-500" data-tool-status>Ready</span>
      </div>
      <textarea class="tool-textarea min-h-[24rem] rounded-[1.5rem] bg-slate-950 text-slate-100 placeholder:text-slate-500 focus:border-sky-400 focus:ring-sky-100" data-tool-input data-code-language="json" placeholder='{"service":"api","enabled":true}'></textarea>
    </label>
    <label class="block">
      <div class="mb-3 flex items-center justify-between gap-4">
        <span class="text-sm font-semibold text-slate-900">YAML output</span>
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Converter</span>
      </div>
      <textarea class="tool-textarea min-h-[24rem] rounded-[1.5rem] bg-white" data-tool-output data-code-language="yaml" readonly placeholder="YAML will appear here"></textarea>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-7 text-slate-600">
        Review indentation and quoting when moving config data between machine and human workflows.
      </div>
    </label>
  </div>
</ToolShell>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement)) return;
    const input = root.querySelector("[data-tool-input]");
    const output = root.querySelector("[data-tool-output]");
    const status = root.querySelector("[data-tool-status]");
    if (!(input instanceof HTMLTextAreaElement) || !(output instanceof HTMLTextAreaElement) || !(status instanceof HTMLElement)) return;

    const sample = `{"service":"api","ports":[3000,3001],"headers":{"accept":"application/json"},"enabled":true}`;

    const setStatus = (text, ok = true) => {
      status.textContent = text;
      status.className = `status-pill ${ok ? "border-emerald-200 bg-emerald-50 text-emerald-700" : "border-rose-200 bg-rose-50 text-rose-700"}`;
    };

    const formatScalar = (value) => {
      if (typeof value === "string") {
        return JSON.stringify(value);
      }
      if (value === null) return "null";
      return String(value);
    };

    const formatKey = (key) =>
      /^(?:true|false|null|~|-?(?:0|[1-9]\d*)(?:\.\d+)?(?:[eE][+-]?\d+)?)$/.test(key) || !/^[A-Za-z_][A-Za-z0-9_-]*$/.test(key)
        ? JSON.stringify(key)
        : key;

    const toYaml = (value, depth = 0) => {
      const pad = "  ".repeat(depth);
      if (Array.isArray(value)) {
        if (value.length === 0) return `${pad}[]`;
        return value
          .map((item) => {
            if (Array.isArray(item)) {
              const nested = toYaml(item, depth + 1);
              return `${pad}-\n${nested}`;
            }
            if (item && typeof item === "object") {
              const entries = Object.entries(item);
              if (entries.length === 0) return `${pad}- {}`;
              const [firstKey, firstValue] = entries[0];
              const firstLine =
                firstValue && typeof firstValue === "object"
                  ? `${pad}- ${formatKey(firstKey)}:\n${toYaml(firstValue, depth + 2)}`
                  : `${pad}- ${formatKey(firstKey)}: ${formatScalar(firstValue)}`;
              const rest = entries.slice(1).map(([key, nestedValue]) => {
                if (nestedValue && typeof nestedValue === "object") {
                  return `${pad}  ${formatKey(key)}:\n${toYaml(nestedValue, depth + 2)}`;
                }
                return `${pad}  ${formatKey(key)}: ${formatScalar(nestedValue)}`;
              });
              return [firstLine, ...rest].join("\n");
            }
            return `${pad}- ${formatScalar(item)}`;
          })
          .join("\n");
      }
      if (value && typeof value === "object") {
        const entries = Object.entries(value);
        if (entries.length === 0) return `${pad}{}`;
        return entries
          .map(([key, item]) => {
            if (item && typeof item === "object") {
              return `${pad}${formatKey(key)}:\n${toYaml(item, depth + 1)}`;
            }
            return `${pad}${formatKey(key)}: ${formatScalar(item)}`;
          })
          .join("\n");
      }
      return `${pad}${formatScalar(value)}`;
    };

    root.addEventListener("click", (event) => {
      const action = event.target instanceof Element ? event.target.closest("[data-tool-action]")?.getAttribute("data-tool-action") : null;
      if (!action) return;
      if (action === "Sample") {
        input.value = sample;
        output.value = "";
        setStatus("Sample loaded");
      } else if (action === "Clear") {
        input.value = "";
        output.value = "";
        setStatus("Ready");
      } else if (action === "Convert") {
        if (!input.value.trim()) {
          output.value = "Enter JSON to convert.";
          setStatus("Input required", false);
          return;
        }
        try {
          const parsed = JSON.parse(input.value);
          output.value = toYaml(parsed);
          setStatus("Converted");
        } catch (error) {
          output.value = error instanceof Error ? error.message : "Invalid JSON";
          setStatus("Invalid JSON", false);
        }
      }
    });
  })();
</script>
