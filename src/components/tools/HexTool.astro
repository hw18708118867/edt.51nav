---
import ToolShell from "@/components/tool/ToolShell.astro";
---

<ToolShell
  toolId="hex"
  title="Hex Encode / Decode"
  description="Convert UTF-8 text to hexadecimal bytes or decode hex back into readable text for payload inspection and debugging."
  controls={["Encode", "Decode", "Clear", "Sample"]}
>
  <div class="mt-6 grid gap-6 xl:grid-cols-[1fr_320px]">
    <label class="block">
      <div class="mb-3 flex items-center justify-between gap-4">
        <span class="text-sm font-semibold text-slate-900">Input</span>
        <span class="status-pill border-slate-200 bg-slate-50 text-slate-500" data-tool-status>Ready</span>
      </div>
      <textarea class="tool-textarea min-h-[24rem] rounded-[1.5rem] bg-slate-950 text-slate-100 placeholder:text-slate-500 focus:border-sky-400 focus:ring-sky-100" data-tool-input data-code-language="text" placeholder="Paste text or a hex string here"></textarea>
    </label>
    <label class="block">
      <div class="mb-3 flex items-center justify-between gap-4">
        <span class="text-sm font-semibold text-slate-900">Output</span>
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Hex bytes</span>
      </div>
      <textarea class="tool-textarea min-h-[24rem] rounded-[1.5rem] bg-white" data-tool-output data-code-language="text" readonly placeholder="Result will appear here"></textarea>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-7 text-slate-600">
        Hex output is grouped without separators by default so you can paste it directly into scripts, docs, or transport tooling.
      </div>
    </label>
  </div>
</ToolShell>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement)) return;
    const input = root.querySelector("[data-tool-input]");
    const output = root.querySelector("[data-tool-output]");
    const status = root.querySelector("[data-tool-status]");
    if (!(input instanceof HTMLTextAreaElement) || !(output instanceof HTMLTextAreaElement) || !(status instanceof HTMLElement)) return;

    const sample = "DevTools";

    const setStatus = (text, ok = true) => {
      status.textContent = text;
      status.className = `status-pill ${ok ? "border-emerald-200 bg-emerald-50 text-emerald-700" : "border-rose-200 bg-rose-50 text-rose-700"}`;
    };

    const encodeHex = (value) =>
      Array.from(new TextEncoder().encode(value))
        .map((byte) => byte.toString(16).padStart(2, "0"))
        .join("");

    const decodeHex = (value) => {
      const normalized = value.replace(/\s+/g, "");
      if (!normalized) {
        return "";
      }
      if (normalized.length % 2 !== 0 || /[^0-9a-fA-F]/.test(normalized)) {
        throw new Error("Hex input must contain an even number of hexadecimal characters.");
      }
      const bytes = new Uint8Array(normalized.match(/.{1,2}/g)?.map((pair) => parseInt(pair, 16)) ?? []);
      return new TextDecoder("utf-8", { fatal: true }).decode(bytes);
    };

    root.addEventListener("click", (event) => {
      const action = event.target instanceof Element ? event.target.closest("[data-tool-action]")?.getAttribute("data-tool-action") : null;
      if (!action) return;
      if (action === "Sample") {
        input.value = sample;
        output.value = "";
        setStatus("Sample loaded");
      } else if (action === "Clear") {
        input.value = "";
        output.value = "";
        setStatus("Ready");
      } else if (action === "Encode") {
        output.value = encodeHex(input.value);
        setStatus("Encoded");
      } else if (action === "Decode") {
        try {
          output.value = decodeHex(input.value);
          setStatus("Decoded");
        } catch (error) {
          output.value = error instanceof Error ? error.message : "Decode failed";
          setStatus("Decode failed", false);
        }
      }
    });
  })();
</script>
