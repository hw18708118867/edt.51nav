---
import type { CategorySlug } from "@/data/site-content";
import { resolveToolVisual } from "@/lib/tool-visuals";

interface Props {
  toolId?: string;
  title?: string;
  category?: CategorySlug;
  size?: "xs" | "sm" | "md" | "lg" | "xl";
}

const { toolId, title, category, size = "md" } = Astro.props;

const visual = resolveToolVisual({ id: toolId, title, category });

const sizeClasses = {
  xs: "h-8 w-8 rounded-xl",
  sm: "h-9 w-9 rounded-xl",
  md: "h-11 w-11 rounded-2xl",
  lg: "h-12 w-12 rounded-2xl",
  xl: "h-14 w-14 rounded-[1.35rem]"
};
---

<span class:list={["tool-glyph", sizeClasses[size]]} data-tone={visual.tone} aria-hidden="true">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    {
      visual.icon === "braces" && (
        <>
          <path d="M9 4H7.5C6.672 4 6 4.672 6 5.5V8C6 9.105 5.105 10 4 10C5.105 10 6 10.895 6 12V14.5C6 15.328 6.672 16 7.5 16H9" />
          <path d="M15 4H16.5C17.328 4 18 4.672 18 5.5V8C18 9.105 18.895 10 20 10C18.895 10 18 10.895 18 12V14.5C18 15.328 17.328 16 16.5 16H15" />
          <path d="M10 8H14" />
          <path d="M10 12H14" />
        </>
      )
    }
    {
      visual.icon === "shield-check" && (
        <>
          <path d="M12 3L18 5.5V10C18 14.2 15.42 17.96 12 19C8.58 17.96 6 14.2 6 10V5.5L12 3Z" />
          <path d="M9.5 10.5L11.2 12.2L14.8 8.6" />
        </>
      )
    }
    {
      visual.icon === "compare" && (
        <>
          <rect x="4" y="5" width="6" height="14" rx="2" />
          <rect x="14" y="5" width="6" height="14" rx="2" />
          <path d="M10 9H14" />
          <path d="M14 15H10" />
        </>
      )
    }
    {
      visual.icon === "compress" && (
        <>
          <path d="M8 4H4V8" />
          <path d="M16 4H20V8" />
          <path d="M8 20H4V16" />
          <path d="M16 20H20V16" />
          <path d="M9 9L4 4" />
          <path d="M15 9L20 4" />
          <path d="M9 15L4 20" />
          <path d="M15 15L20 20" />
        </>
      )
    }
    {
      visual.icon === "yaml-flow" && (
        <>
          <path d="M5 6H9L7 10" />
          <path d="M7 10V18" />
          <path d="M14 6H19" />
          <path d="M14 10H19" />
          <path d="M14 14H19" />
          <path d="M9 12H12.5" />
          <path d="M11 10.5L12.5 12L11 13.5" />
        </>
      )
    }
    {
      visual.icon === "token" && (
        <>
          <rect x="3.5" y="7" width="17" height="10" rx="3" />
          <path d="M8 7V17" />
          <path d="M16 7V17" />
          <path d="M10.5 10H13.5" />
          <path d="M10.5 14H13.5" />
        </>
      )
    }
    {
      visual.icon === "binary" && (
        <>
          <path d="M6.5 7V17" />
          <path d="M5 8.5C5 7.672 5.672 7 6.5 7C7.328 7 8 7.672 8 8.5V15.5C8 16.328 7.328 17 6.5 17C5.672 17 5 16.328 5 15.5" />
          <path d="M14 8.5L16.5 7V17" />
          <path d="M19 8.5L21.5 7V17" />
        </>
      )
    }
    {
      visual.icon === "link-code" && (
        <>
          <path d="M10 8L7.5 10.5C6.672 11.328 6.672 12.672 7.5 13.5C8.328 14.328 9.672 14.328 10.5 13.5L13 11" />
          <path d="M14 16L16.5 13.5C17.328 12.672 17.328 11.328 16.5 10.5C15.672 9.672 14.328 9.672 13.5 10.5L11 13" />
          <path d="M4 6H8" />
          <path d="M16 18H20" />
        </>
      )
    }
    {
      visual.icon === "percent-link" && (
        <>
          <path d="M8 7C8 8.105 7.105 9 6 9C4.895 9 4 8.105 4 7C4 5.895 4.895 5 6 5C7.105 5 8 5.895 8 7Z" />
          <path d="M20 17C20 18.105 19.105 19 18 19C16.895 19 16 18.105 16 17C16 15.895 16.895 15 18 15C19.105 15 20 15.895 20 17Z" />
          <path d="M7 17L17 7" />
          <path d="M9.5 12H14.5" />
        </>
      )
    }
    {
      visual.icon === "angle-brackets" && (
        <>
          <path d="M9 7L4 12L9 17" />
          <path d="M15 7L20 12L15 17" />
          <path d="M12.5 5L11.5 19" />
        </>
      )
    }
    {
      visual.icon === "unicode" && (
        <>
          <circle cx="12" cy="12" r="8" />
          <path d="M8.5 10.5C9.2 9 10.4 8 12 8C13.6 8 14.8 9 15.5 10.5" />
          <path d="M8.5 13.5C9.2 15 10.4 16 12 16C13.6 16 14.8 15 15.5 13.5" />
          <path d="M12 4V20" />
        </>
      )
    }
    {
      visual.icon === "hexagon" && (
        <>
          <path d="M9 4.5H15L19 8.5V15.5L15 19.5H9L5 15.5V8.5L9 4.5Z" />
          <path d="M9.5 12H14.5" />
          <path d="M10.5 9.5V14.5" />
        </>
      )
    }
    {
      visual.icon === "hash" && (
        <>
          <path d="M9 4L7 20" />
          <path d="M17 4L15 20" />
          <path d="M4 9H20" />
          <path d="M3 15H19" />
        </>
      )
    }
    {
      visual.icon === "key-lock" && (
        <>
          <rect x="11" y="11" width="8" height="8" rx="2" />
          <path d="M13 11V9.75C13 8.231 14.231 7 15.75 7C17.269 7 18.5 8.231 18.5 9.75V11" />
          <path d="M5 13.5H8.5" />
          <path d="M5 13.5V10.5C5 9.119 6.119 8 7.5 8C8.881 8 10 9.119 10 10.5C10 11.881 8.881 13 7.5 13H6.5" />
        </>
      )
    }
    {
      visual.icon === "pulse" && (
        <>
          <rect x="3.5" y="5" width="17" height="14" rx="3" />
          <path d="M4 12H7L9.2 8L12.4 16L14.8 11H20" />
        </>
      )
    }
    {
      visual.icon === "regex" && (
        <>
          <path d="M6 8L9 12L6 16" />
          <path d="M12 7L16 17" />
          <path d="M18.5 8.5C18.5 9.328 17.828 10 17 10C16.172 10 15.5 9.328 15.5 8.5C15.5 7.672 16.172 7 17 7C17.828 7 18.5 7.672 18.5 8.5Z" />
          <path d="M18.5 15.5C18.5 16.328 17.828 17 17 17C16.172 17 15.5 16.328 15.5 15.5C15.5 14.672 16.172 14 17 14C17.828 14 18.5 14.672 18.5 15.5Z" />
        </>
      )
    }
  </svg>
</span>
