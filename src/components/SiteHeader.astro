---
import { primaryNav } from "@/config/site";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { tools } from "@/data/site-content";
import { getToolPath } from "@/lib/tool-links";

const pathname = Astro.url.pathname;

const navItems = primaryNav.map((item) => {
  const categorySlug =
    item.href !== "/tools/" && item.href !== "/blog/"
      ? item.href.replaceAll("/", "")
      : null;

  return {
    ...item,
    children: categorySlug
      ? tools
          .filter((tool) => tool.category === categorySlug)
          .map((tool) => ({
            href: getToolPath(tool.category, tool.slug),
            label: tool.title
          }))
      : []
  };
});
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/72 backdrop-blur-2xl">
  <div class="shell flex min-h-18 flex-wrap items-center justify-between gap-4 py-4 lg:flex-nowrap lg:gap-6">
    <a href="/" class="flex items-center gap-3">
      <span class="flex h-11 w-11 items-center justify-center rounded-full bg-slate-950 text-sm font-bold text-white shadow-[0_10px_30px_rgba(15,23,42,0.18)]">EDT</span>
      <div>
        <div class="headline text-base font-bold tracking-tight text-slate-950">Everyday Dev Tools</div>
        <div class="text-xs text-slate-500">Fast tools, no fuss</div>
      </div>
    </a>

    <div class="hidden items-center gap-3 lg:flex">
    <nav class="items-center gap-2 lg:flex">
      {
        navItems.map((item) => {
          const active = pathname === item.href || pathname.startsWith(item.href);
          const hasChildren = item.children.length > 0;

          return hasChildren ? (
            <details class="nav-dropdown group relative">
              <summary
                class:list={[
                  "nav-summary rounded-full px-4 py-2 text-sm font-medium transition",
                  active
                    ? "bg-slate-950 text-white"
                    : "text-slate-600 hover:bg-slate-100 hover:text-slate-950"
                ]}
              >
                {item.label}
                <svg
                  class:list={[
                    "h-3.5 w-3.5 transition duration-200 group-hover:rotate-180 group-focus-within:rotate-180",
                    active ? "text-white" : "text-slate-400"
                  ]}
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M4 6.5L8 10.5L12 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </summary>
              <div class="pointer-events-none absolute left-0 top-full z-[70] w-72 pt-3 opacity-0 transition duration-150 group-open:pointer-events-auto group-open:opacity-100">
                <div class="rounded-[1.35rem] border border-slate-200/90 bg-white p-3 shadow-[0_28px_70px_rgba(15,23,42,0.14)] ring-1 ring-slate-950/5 backdrop-blur-xl">
                  <div class="mb-2 px-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                    {item.label} tools
                  </div>
                  <div class="space-y-1">
                    {
                      item.children.map((child) => {
                        const childActive = pathname === child.href || pathname.startsWith(child.href);
                        return (
                          <a
                            href={child.href}
                            class:list={[
                              "block rounded-2xl px-3 py-2.5 text-sm font-medium transition",
                              childActive
                                ? "bg-slate-950 text-white"
                                : "text-slate-700 hover:bg-slate-100 hover:text-slate-950"
                            ]}
                          >
                            {child.label}
                          </a>
                        );
                      })
                    }
                  </div>
                </div>
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-medium transition",
                active
                  ? "bg-slate-950 text-white"
                  : "text-slate-600 hover:bg-slate-100 hover:text-slate-950"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
      <ThemeToggle />
    </div>

    <nav class="w-full lg:hidden">
      <div class="flex items-start gap-2 overflow-x-auto pb-1">
      {
        navItems.map((item) => {
          const active = pathname === item.href || pathname.startsWith(item.href);
          const hasChildren = item.children.length > 0;

          return hasChildren ? (
            <details class="nav-dropdown-mobile">
              <summary
                class:list={[
                  "nav-summary whitespace-nowrap rounded-full px-4 py-2 text-sm font-medium transition",
                  active
                    ? "bg-slate-950 text-white"
                    : "bg-white text-slate-600 hover:bg-slate-100 hover:text-slate-950"
                ]}
              >
                <span>{item.label}</span>
                <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6.5L8 10.5L12 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </summary>
              <div class="mt-2 rounded-[1.35rem] border border-slate-200 bg-white p-3 shadow-[0_18px_40px_rgba(15,23,42,0.08)] ring-1 ring-slate-950/5">
                <div class="mb-2 px-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                  {item.label} tools
                </div>
                <div class="space-y-1">
                  {
                    item.children.map((child) => {
                      const childActive = pathname === child.href || pathname.startsWith(child.href);
                      return (
                        <a
                          href={child.href}
                          class:list={[
                            "block rounded-2xl px-3 py-2.5 text-sm font-medium transition",
                            childActive
                              ? "bg-slate-950 text-white"
                              : "text-slate-700 hover:bg-slate-100 hover:text-slate-950"
                          ]}
                        >
                          {child.label}
                        </a>
                      );
                    })
                  }
                </div>
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class:list={[
                "whitespace-nowrap rounded-full px-4 py-2 text-sm font-medium transition",
                active
                  ? "bg-slate-950 text-white"
                  : "bg-white text-slate-600 hover:bg-slate-100 hover:text-slate-950"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <ThemeToggle />
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const dropdowns = Array.from(document.querySelectorAll(".nav-dropdown"));
    const closeTimers = new WeakMap();

    dropdowns.forEach((dropdown) => {
      if (!(dropdown instanceof HTMLDetailsElement)) return;
      const summary = dropdown.querySelector("summary");
      if (!(summary instanceof HTMLElement)) return;

      const openDropdown = () => {
        const timer = closeTimers.get(dropdown);
        if (timer) {
          window.clearTimeout(timer);
          closeTimers.delete(dropdown);
        }
        dropdowns.forEach((item) => {
          if (item instanceof HTMLDetailsElement && item !== dropdown) item.open = false;
        });
        dropdown.open = true;
      };

      const closeDropdown = () => {
        const timer = window.setTimeout(() => {
          dropdown.open = false;
          closeTimers.delete(dropdown);
        }, 120);
        closeTimers.set(dropdown, timer);
      };

      dropdown.addEventListener("mouseenter", openDropdown);
      dropdown.addEventListener("mouseleave", closeDropdown);
      dropdown.addEventListener("focusin", openDropdown);
      dropdown.addEventListener("focusout", (event) => {
        const nextTarget = event.relatedTarget;
        if (!(nextTarget instanceof Node) || !dropdown.contains(nextTarget)) {
          closeDropdown();
        }
      });

      summary.addEventListener("click", (event) => {
        event.preventDefault();
        openDropdown();
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target instanceof Node ? event.target : null;
      if (!target) return;
      dropdowns.forEach((dropdown) => {
        if (!(dropdown instanceof HTMLDetailsElement)) return;
        if (!dropdown.contains(target)) dropdown.open = false;
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      dropdowns.forEach((dropdown) => {
        if (dropdown instanceof HTMLDetailsElement) dropdown.open = false;
      });
    });
  })();
</script>
