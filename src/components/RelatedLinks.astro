---
interface LinkItem {
  href: string;
  label: string;
  description?: string;
}

interface Props {
  title: string;
  items: LinkItem[];
}

const { title, items } = Astro.props;
---

<section class="section-card">
  <h2 class="headline text-3xl font-bold tracking-tight text-slate-950">{title}</h2>
  <div class="mt-6 grid gap-4 md:grid-cols-2">
    {
      items.map((item) => (
        <a href={item.href} class="rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-slate-300 hover:shadow-sm">
          <div class="text-base font-semibold text-slate-950">{item.label}</div>
          {item.description && <p class="mt-2 text-sm leading-7 text-slate-600">{item.description}</p>}
        </a>
      ))
    }
  </div>
</section>
