---
import ToolCard from "@/components/ToolCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { tools } from "@/data/site-content";
import { categories } from "@/data/site-content";
import { buildWebsiteJsonLd } from "@/lib/json-ld";
import { buildSeo } from "@/lib/seo";

const seo = buildSeo({
  title: "All Developer Tools",
  description:
    "Browse JSON, JWT, encoding, API, and regex tools for common developer tasks.",
  path: "/tools/",
  keywords: ["all developer tools", "json jwt regex tools", "developer utility tools"]
});
---

<BaseLayout seo={seo} jsonLd={[buildWebsiteJsonLd()]}>
  <section class="shell relative overflow-hidden pt-14 pb-20 lg:pt-18 lg:pb-24">
    <div class="aurora-layer"></div>
    <div class="hero-trails"></div>
    <div class="pointer-events-none absolute inset-x-0 top-14 -z-10 mx-auto h-72 max-w-5xl rounded-full bg-gradient-to-r from-sky-200/20 via-white/80 to-slate-200/20 blur-3xl"></div>
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="max-w-3xl">
        <div class="eyebrow">All Tools</div>
        <h1 class="headline mt-6 text-5xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-6xl">
          All tools in one place.
        </h1>
        <p class="mt-5 text-lg leading-9 text-slate-600">
          Start with the task you need to finish: clean up JSON, inspect a token, decode text, test a regex, or check an endpoint.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 text-sm text-slate-500">
          <span class="status-pill border-slate-200 bg-white/70 text-slate-600">{tools.length} tools live</span>
          <span class="status-pill border-slate-200 bg-white/70 text-slate-600">{categories.length} categories</span>
          <span class="status-pill border-slate-200 bg-white/70 text-slate-600">Static delivery</span>
        </div>
      </div>
      <div class="hero-monitor relative overflow-hidden rounded-[2rem] p-5 sm:p-6">
        <div class="grid-lines absolute inset-0"></div>
        <div class="noise-layer"></div>
        <div class="relative">
          <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">How to navigate</div>
          <div class="mt-4 grid gap-3">
            <div class="rounded-2xl border border-slate-200 bg-white/88 p-4">
              <div class="text-sm font-semibold text-slate-950">Start with the task</div>
              <p class="mt-1 text-sm leading-7 text-slate-600">Pick the thing you are trying to do, then open the closest tool.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white/88 p-4">
              <div class="text-sm font-semibold text-slate-950">Pick a category</div>
              <p class="mt-1 text-sm leading-7 text-slate-600">JSON, JWT, Encode, API, and Regex keep similar tools grouped together.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white/88 p-4">
              <div class="text-sm font-semibold text-slate-950">Open the workbench</div>
              <p class="mt-1 text-sm leading-7 text-slate-600">Each page keeps the same basic layout so you do not have to relearn the interface.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="shell pb-20 lg:pb-24">
    <div class="surface flex flex-col gap-6 rounded-[2rem] px-6 py-5 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Directory system</div>
        <p class="mt-2 text-sm leading-7 text-slate-600">
          The catalog stays simple: short URLs, familiar page structure, and enough context to know what each tool is for.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 text-sm font-semibold text-slate-500">
        <span class="rounded-full border border-slate-200 bg-white px-4 py-2">Tool-first routing</span>
        <span class="rounded-full border border-slate-200 bg-white px-4 py-2">FAQ-led SEO</span>
        <span class="rounded-full border border-slate-200 bg-white px-4 py-2">Reusable content model</span>
      </div>
    </div>
  </section>

  <section class="shell pb-24">
    <div class="flex items-end justify-between gap-6">
      <div>
        <div class="eyebrow">Launch Directory</div>
        <h2 class="headline mt-4 text-3xl font-semibold tracking-[-0.03em] text-slate-950 sm:text-4xl">Current tools</h2>
      </div>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {tools.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>
</BaseLayout>
