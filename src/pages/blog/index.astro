---
import ArticleCard from "@/components/ArticleCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles } from "@/data/site-content";
import { buildWebsiteJsonLd } from "@/lib/json-ld";
import { buildSeo } from "@/lib/seo";

const seo = buildSeo({
  title: "Developer Tools Blog",
  description:
    "Short guides around JSON, JWT, encoding, API debugging, and regex work.",
  path: "/blog/",
  keywords: ["developer blog", "json tutorial", "jwt guide", "regex debugging"]
});
---

<BaseLayout seo={seo} jsonLd={[buildWebsiteJsonLd()]}>
  <section class="shell relative overflow-hidden pt-14 pb-20 lg:pt-18 lg:pb-24">
    <div class="aurora-layer"></div>
    <div class="hero-trails"></div>
    <div class="pointer-events-none absolute inset-x-0 top-14 -z-10 mx-auto h-72 max-w-5xl rounded-full bg-gradient-to-r from-sky-200/20 via-white/80 to-slate-200/20 blur-3xl"></div>
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="max-w-3xl">
      <div class="eyebrow">Blog</div>
      <h1 class="headline mt-6 text-5xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-6xl">Short guides for the questions that come next</h1>
      <p class="mt-5 text-lg leading-9 text-slate-600">
        These articles are meant to be practical, not fluffy. They cover the follow-up questions people usually have after opening one of the tools.
      </p>
      </div>
      <div class="hero-monitor relative overflow-hidden rounded-[2rem] p-5 sm:p-6">
        <div class="grid-lines absolute inset-0"></div>
        <div class="noise-layer"></div>
        <div class="relative">
          <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Editorial system</div>
          <div class="mt-4 grid gap-3">
            <div class="rounded-2xl border border-slate-200 bg-white/88 p-4">
              <div class="text-sm font-semibold text-slate-950">Written to be useful first</div>
              <p class="mt-1 text-sm leading-7 text-slate-600">The goal is to answer the thing someone was actually trying to figure out.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white/88 p-4">
              <div class="text-sm font-semibold text-slate-950">Close to the tools</div>
              <p class="mt-1 text-sm leading-7 text-slate-600">Each article points back to the tools that are actually useful for that topic.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="shell pb-24">
    <div class="mt-0 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
